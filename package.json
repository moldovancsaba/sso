{
  "name": "@moldovancsaba/universal-sso",
  "version": "5.29.0",
  "description": "A universal Single Sign-On (SSO) service that can be integrated into any project",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 5500",
    "build": "next build",
    "start": "next start -p $PORT",
    "lint": "eslint . --ext .js,.jsx,.mjs,.cjs,.ts,.tsx",
    "lint:gds": "eslint --config eslint.gds.config.mjs . --ext .js,.jsx,.mjs,.cjs,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "test:contracts": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "guard:repo": "node scripts/check-repo-guardrails.mjs",
    "check:docs": "node scripts/check-docs-maintenance.mjs",
    "gds:validate-manifest": "gds-compliance validate-manifest --manifest ./gds-adoption.json",
    "gds:check": "gds-compliance check --manifest ./gds-adoption.json",
    "validate-config": "node -e \"import('./lib/config.js').then(c => c.validateConfig())\"",
    "test-connection": "node scripts/test-connection.js",
    "setup": "cp .env.example .env && echo 'Please edit .env with your configuration'",
    "vercel-build": "next build",
    "sync:version": "node scripts/sync-version.mjs"
  },
  "keywords": [
    "sso",
    "authentication",
    "single-sign-on",
    "nextjs",
    "mongodb",
    "universal",
    "oauth",
    "session-management"
  ],
  "author": "Moldovan Csaba",
  "license": "MIT",
  "dependencies": {
    "@doneisbetter/gds": "3.0.0",
    "@doneisbetter/gds-admin": "3.0.0",
    "@doneisbetter/gds-core": "3.0.0",
    "@doneisbetter/gds-theme": "3.0.0",
    "@mantine/core": "9.2.1",
    "@mantine/form": "9.2.1",
    "@mantine/hooks": "9.2.1",
    "@mantine/modals": "9.2.1",
    "@mantine/notifications": "9.2.1",
    "@tabler/icons-react": "3.44.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express-rate-limit": "7.5.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^6.0.0",
    "next": "15.5.18",
    "nodemailer": "8.0.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "6.1.2",
    "winston": "3.18.3",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@doneisbetter/gds-compliance": "3.0.0",
    "@doneisbetter/gds-eslint-config": "3.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.19.40",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.18",
    "jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=8.0.0"
  },
  "overrides": {
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "@typescript-eslint/typescript-estree": {
      "brace-expansion": "5.0.6"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/moldovancsaba/sso.git"
  },
  "bugs": {
    "url": "https://github.com/moldovancsaba/sso/issues"
  },
  "homepage": "https://github.com/moldovancsaba/sso#readme"
}
