{
  "name": "universal-sso",
  "version": "1.0.0",
  "description": "A universal Single Sign-On (SSO) service that can be integrated into any project",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "validate-config": "node -e \"import('./lib/config.js').then(c => c.validateConfig())\"",
    "test-connection": "node scripts/test-connection.js",
    "setup": "cp .env.example .env && echo 'Please edit .env with your configuration'"
  },
  "keywords": [
    "sso",
    "authentication",
    "single-sign-on",
    "nextjs",
    "mongodb",
    "universal",
    "oauth",
    "session-management"
  ],
  "author": "SSO Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^6.0.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/universal-sso.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/universal-sso/issues"
  },
  "homepage": "https://github.com/yourusername/universal-sso#readme"
}
