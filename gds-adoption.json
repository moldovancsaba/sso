{
  "schemaVersion": 1,
  "gdsVersion": "2.6.3",
  "productArchetype": "hybrid",
  "supportedEntryPoints": [
    "@doneisbetter/gds-theme/client",
    "@doneisbetter/gds-theme/server",
    "@doneisbetter/gds-core/server",
    "@doneisbetter/gds-admin/client",
    "@doneisbetter/gds-admin/server"
  ],
  "requiredContracts": [
    "AppShell",
    "PageHeader",
    "DataToolbar",
    "ResponsiveDataView",
    "AuthShell",
    "ArticleShell",
    "PublicShell",
    "StateBlock",
    "EditorialHero",
    "FeatureBand",
    "ConsumerSection",
    "EditorialCard"
  ],
  "localAdapters": [
    {
      "contract": "DocsPageShell",
      "path": "components/DocsLayout.js",
      "status": "active"
    },
    {
      "contract": "AppFooter",
      "path": "components/AppFooter.js",
      "status": "active"
    }
  ],
  "approvedExceptions": [
    {
      "surface": "OAuth provider buttons",
      "reason": "Google and Facebook provider branding rules still require narrow custom presentation during the current migration phase.",
      "owner": "sso-platform",
      "reviewDate": "2026-05-27"
    },
    {
      "surface": "Docs editorial surfaces",
      "reason": "The docs area still carries a local docs-site shell wrapper and two targeted lint waivers on long-form prose-heavy docs pages.",
      "owner": "sso-platform",
      "reviewDate": "2026-05-29"
    }
  ],
  "compliance": {
    "documentationPaths": [
      "README.md",
      "docs/README.md",
      "docs/ARCHITECTURE.md",
      "docs/DESIGN_SYSTEM.md"
    ],
    "staleDocumentationReferences": [
      "@gds/",
      "/Users/Shared/Projects/GENERAL_DESIGN_SYSTEM"
    ],
    "protectedSurfacePaths": [
      "components",
      "lib/theme",
      "pages"
    ],
    "bannedImports": [
      "@gds/theme",
      "@gds/theme/client",
      "@gds/theme/server",
      "@gds/core",
      "@gds/core/client",
      "@gds/core/server",
      "@gds/admin",
      "@gds/admin/client",
      "@gds/admin/server",
      "@gds/eslint-config",
      "@gds/compliance"
    ]
  },
  "migrationStatus": "mostly-direct",
  "owner": "sso-platform",
  "lastReviewedAt": "2026-05-29"
}
